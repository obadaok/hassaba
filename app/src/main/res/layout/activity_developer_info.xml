<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/grey_bg"
    android:layoutDirection="rtl"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/topBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_surface"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="عن التطبيق"
            android:textColor="@color/bronze_accent"
            android:textSize="22sp"
            android:textStyle="bold" />

        <com.mikepenz.iconics.view.IconicsImageView
            android:id="@+id/btnCloseDev"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:iiv_color="@color/text_secondary"
            app:iiv_icon="faw-arrow-left"
            app:iiv_size="24dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp"
                android:weightSum="2"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        app:cardBackgroundColor="@color/card_surface"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="4dp"
                        app:strokeColor="@color/bronze_accent"
                        app:strokeWidth="1dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="20dp"
                            android:src="@drawable/logo"
                            app:tint="@color/bronze_accent" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="معمل أبو إدريس\nلمعايرة وتحليل الذهب"
                        android:textColor="@color/bronze_accent"
                        android:textStyle="bold"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        app:cardBackgroundColor="@color/card_surface"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="4dp"
                        app:strokeColor="@color/bronze_accent"
                        app:strokeWidth="1dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="16dp"
                            android:src="@drawable/ico" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="الحسابة البرونزية"
                        android:textColor="@color/bronze_accent"
                        android:textStyle="bold"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- بطاقة الوصف مع زر "عرض المزيد" -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="عن الحسابة"
                        android:textColor="@color/bronze_accent"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <!-- النص المختصر (يظهر دائماً) -->
                    <TextView
                        android:id="@+id/tvShortDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="8dp"
                        android:text="آلة حاسبة متطورة مصممة لتسهيل العمليات الحسابية اليومية والتجارية، تتميز بالعمل كنافذة عائمة مرنة فوق التطبيقات الأخرى.\n\n• النافذة العائمة والفقاعة: أداء العمليات أثناء استخدام تطبيقات أخرى مع دعم النوافذ المتعددة.\n• القائمة الدائرية: وصول سريع للسجل وتغيير المظهر.\n• محرك ذكي: معاينة فورية للنتائج وتلوين الرموز لتسهيل القراءة."
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <!-- النص الكامل (مخفي في البداية) -->
                    <TextView
                        android:id="@+id/tvFullDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:lineSpacingExtra="8dp"
                        android:layout_marginTop="12dp"
                        android:text="• سجل متكامل: حفظ تلقائي للعمليات واستعادتها بضغطة.\n• تصميم عصري: دعم الوضع الداكن والفاتح مع تأثيرات حركية سلسة.\n• النسخ السريع: نسخ النتائج بالضغط المطول.\n• إدخال صوتي: تحدث بالعملية الحسابية ويتم تحويلها فوراً.\n• دقة عالية: استخدام MathContext.DECIMAL128 لحسابات علمية دقيقة."
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <!-- زر عرض المزيد / عرض أقل -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReadMore"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="عرض المزيد"
                        android:textAllCaps="false"
                        android:textColor="@color/bronze_accent"
                        app:strokeColor="@color/bronze_accent"
                        app:strokeWidth="1dp"
                        app:cornerRadius="20dp"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- معلومات المعمل والمطور -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="معمل أبو إدريس لمعايرة الذهب بالليزر"
                        android:textColor="@color/bronze_accent"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="الفرع: نورايا"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"/>

                    <View
                        android:layout_width="80dp"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="@color/border"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="المطور: عبادة كمال"
                        android:textColor="@color/bronze_accent"
                        android:textStyle="bold"
                        android:textSize="15sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- الأزرار الثلاثة -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="24dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnFacebookInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:minHeight="50dp"
                    app:cardBackgroundColor="@color/bronze_accent"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:paddingVertical="12dp"
                        android:gravity="center">
                        <com.mikepenz.iconics.view.IconicsImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginBottom="4dp"
                            app:iiv_icon="faw-facebook"
                            app:iiv_color="#FFFFFF"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="فيسبوك"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnPrivacyPolicy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:minHeight="50dp"
                    app:cardBackgroundColor="@color/bronze_accent"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:paddingVertical="12dp"
                        android:gravity="center">
                        <com.mikepenz.iconics.view.IconicsImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginBottom="4dp"
                            app:iiv_icon="faw-shield_alt"
                            app:iiv_color="#FFFFFF"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الخصوصية"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnDeveloperWebsite"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:minHeight="50dp"
                    app:cardBackgroundColor="@color/bronze_accent"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:paddingVertical="12dp"
                        android:gravity="center">
                        <com.mikepenz.iconics.view.IconicsImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginBottom="4dp"
                            app:iiv_icon="faw-globe"
                            app:iiv_color="#FFFFFF"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الموقع"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>